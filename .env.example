# ---------------------------------------------------------------------------
# MLflow — standard MLflow env vars, read by both the SDK and training code
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=databricks        # or "file:./mlruns" for local
MLFLOW_EXPERIMENT_NAME=               # e.g. /Users/you@email.com/argus

# Required when MLFLOW_TRACKING_URI=databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# ---------------------------------------------------------------------------
# Serving
# ---------------------------------------------------------------------------
# Registry URI to pull model from Databricks. Leave blank to use local models/ folder.
# PyTorch backend (default):
CMS_SERVING__MODEL_URI=models:/workspace.default.content-moderation-text@Production
# ONNX backend (set CMS_SERVING__BACKEND=onnx and change the URI):
# CMS_SERVING__MODEL_URI=models:/workspace.default.content-moderation-text-onnx@Production

# ---------------------------------------------------------------------------
# Optimization (optional)
# ---------------------------------------------------------------------------
# Pin a specific MLflow model version when exporting to ONNX
MODEL_VERSION=
